{
	"$schema": "https://biomejs.dev/schemas/2.0.0/schema.json",
	"files": {
		"includes": [
			"**/*",
			"!**/*.d.ts",
			"!**/dist",
			"!**/build",
			"!**/node_modules",
			"!**/.turbo",
			"!**/.wrangler",
			"!**/.output",
			"!**/.stack",
			"!**/.claude/worktrees",
			"!**/storybook-static",
			"!**/coverage",
			"!**/routeTree.gen.ts"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		},
		"formatter": {
			"enabled": true
		}
	}
}
