{
	"name": "@fcalell/ui",
	"version": "0.0.0",
	"type": "module",
	"sideEffects": [
		"**/*.css",
		"./src/fonts.ts"
	],
	"imports": {
		"#components/*": [
			"./src/components/*/index.tsx",
			"./src/components/*/index.ts"
		],
		"#lib/*": [
			"./src/lib/*.ts",
			"./src/lib/*.tsx"
		]
	},
	"exports": {
		"./globals.css": "./src/globals.css",
		"./fonts": "./src/fonts.ts",
		"./fonts-manifest": "./src/fonts-manifest.ts",
		"./app": "./src/app/index.tsx",
		"./meta": "./src/meta/index.ts",
		"./router": "./src/router/index.ts",
		"./components/*": [
			"./src/components/*/index.tsx",
			"./src/components/*/index.ts"
		],
		"./lib/*": [
			"./src/lib/*.ts",
			"./src/lib/*.tsx"
		]
	},
	"files": [
		"src",
		"README.md"
	],
	"license": "MIT",
	"scripts": {
		"check-types": "tsc --noEmit --pretty",
		"lint": "biome check --write --unsafe",
		"check": "pnpm check-types && pnpm lint",
		"clear": "rm -rf node_modules .turbo"
	},
	"peerDependencies": {
		"solid-js": "^1.9",
		"@tanstack/solid-form": "^1.28"
	},
	"peerDependenciesMeta": {
		"@tanstack/solid-form": {
			"optional": true
		}
	},
	"dependencies": {
		"@corvu/otp-field": "^0.1.4",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@kobalte/core": "^0.13.11",
		"@solidjs/meta": "^0.29.4",
		"@solidjs/router": "^0.16.1",
		"@tanstack/solid-query": "^5.97.0",
		"@tanstack/solid-table": "^8.21.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-solid": "^0.577.0",
		"solid-sonner": "^0.3.1",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@fcalell/typescript-config": "workspace:*",
		"@tanstack/solid-form": "^1.28.6",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3"
	}
}
