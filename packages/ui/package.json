{
	"name": "@fcalell/ui",
	"version": "0.0.0",
	"type": "module",
	"sideEffects": [
		"**/*.css"
	],
	"imports": {
		"#components/*": "./src/components/*/index.tsx",
		"#lib/*": "./src/lib/*.ts"
	},
	"exports": {
		"./globals.css": "./src/globals.css",
		"./fonts": "./src/fonts.ts",
		"./components/*": "./src/components/*/index.ts",
		"./lib/*": "./src/lib/*.ts"
	},
	"license": "MIT",
	"scripts": {
		"check-types": "tsc --noEmit --pretty || true",
		"lint": "biome check --write --unsafe",
		"check": "pnpm check-types && pnpm lint",
		"clear": "rm -rf node_modules .turbo"
	},
	"peerDependencies": {
		"solid-js": "^1.9"
	},
	"dependencies": {
		"@corvu/otp-field": "^0.1.4",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@kobalte/core": "^0.13.11",
		"@tanstack/solid-table": "^8.21.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-solid": "^0.577.0",
		"solid-sonner": "^0.3.1",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@fcalell/typescript-config": "workspace:*",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3"
	}
}
