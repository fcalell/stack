{
	"name": "@fcalell/cli",
	"version": "0.0.0",
	"type": "module",
	"sideEffects": false,
	"imports": {
		"#*": "./src/*.ts"
	},
	"exports": {
		".": "./src/config.ts",
		"./events": "./src/events.ts",
		"./codegen": "./src/lib/codegen-v2.ts",
		"./discovery": "./src/lib/discovery.ts"
	},
	"bin": {
		"stack": "./src/cli.ts"
	},
	"license": "MIT",
	"scripts": {
		"check-types": "tsc --noEmit --pretty",
		"lint": "biome check --write --unsafe",
		"check": "pnpm check-types && pnpm lint",
		"test": "vitest run",
		"clear": "rm -rf node_modules .turbo"
	},
	"dependencies": {
		"@clack/prompts": "^0.11.0",
		"magicast": "^0.5.2",
		"picocolors": "^1.1.0"
	},
	"peerDependencies": {
		"tsx": ">=4.0.0"
	},
	"devDependencies": {
		"@fcalell/typescript-config": "workspace:*",
		"@types/node": "^25.5.0",
		"tsx": "^4.19.0",
		"typescript": "^5.9.3"
	}
}
