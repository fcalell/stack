{
	"name": "@fcalell/cli",
	"version": "0.0.0",
	"type": "module",
	"sideEffects": false,
	"imports": {
		"#ast": "./src/ast/index.ts",
		"#ast/*": "./src/ast/*.ts",
		"#*": "./src/*.ts"
	},
	"exports": {
		".": "./src/config.ts",
		"./ast": "./src/ast/index.ts",
		"./specs": "./src/specs.ts",
		"./errors": "./src/lib/errors.ts",
		"./slots": "./src/lib/slots.ts",
		"./cli-slots": "./src/lib/cli-slots.ts",
		"./graph": "./src/lib/graph.ts",
		"./runtime": "./src/runtime.ts",
		"./codegen": "./src/lib/codegen.ts",
		"./discovery": "./src/lib/discovery.ts",
		"./testing": "./src/testing.ts"
	},
	"bin": {
		"stack": "./src/cli.ts"
	},
	"license": "MIT",
	"scripts": {
		"check-types": "tsc --noEmit --pretty",
		"lint": "biome check --write --unsafe",
		"check": "pnpm check-types && pnpm lint",
		"test": "vitest run",
		"clear": "rm -rf node_modules .turbo"
	},
	"dependencies": {
		"@clack/prompts": "^0.11.0",
		"magicast": "^0.5.2",
		"node-html-parser": "^7.1.0",
		"picocolors": "^1.1.0",
		"smol-toml": "^1.6.1",
		"ts-morph": "^28.0.0"
	},
	"peerDependencies": {
		"tsx": ">=4.0.0",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@fcalell/typescript-config": "workspace:*",
		"@types/node": "^25.5.0",
		"tsx": "^4.19.0",
		"typescript": "^5.9.3",
		"zod": "^4.3.6"
	}
}
