{
	"name": "@fcalell/api",
	"version": "0.0.0",
	"type": "module",
	"imports": {
		"#*": "./src/*.ts"
	},
	"exports": {
		".": "./src/index.ts",
		"./client": "./src/client.ts",
		"./schema": "./src/lib/zod.ts",
		"./lib/cursor": "./src/lib/cursor.ts",
		"./lib/slugify": "./src/lib/slugify.ts"
	},
	"license": "MIT",
	"scripts": {
		"check-types": "tsc --noEmit --pretty || true",
		"lint": "biome check --write --unsafe",
		"check": "pnpm check-types && pnpm lint",
		"clear": "rm -rf node_modules .turbo"
	},
	"dependencies": {
		"@fcalell/db": "workspace:*",
		"@orpc/client": "^1.13.7",
		"@orpc/server": "^1.13.7",
		"drizzle-orm": "^0.45.1",
		"hono": "^4.12.8",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@fcalell/typescript-config": "workspace:*",
		"better-auth": "^1.5.5",
		"typescript": "^5.9.3"
	}
}
