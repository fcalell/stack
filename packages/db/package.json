{
	"name": "@fcalell/db",
	"version": "0.0.0",
	"type": "module",
	"sideEffects": false,
	"imports": {
		"#*": "./src/*.ts"
	},
	"exports": {
		".": "./src/config.ts",
		"./orm": "./src/orm.ts",
		"./d1": "./src/d1/client.ts",
		"./sqlite": "./src/sqlite/client.ts",
		"./auth/access": "./src/auth/access.ts",
		"./auth/infer": "./src/auth/infer.ts"
	},
	"license": "MIT",
	"scripts": {
		"check-types": "tsc --noEmit --pretty",
		"lint": "biome check --write --unsafe",
		"check": "pnpm check-types && pnpm lint",
		"clear": "rm -rf node_modules .turbo"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.1"
	},
	"peerDependencies": {
		"better-auth": "^1.5.0",
		"better-sqlite3": "^12.0.0"
	},
	"peerDependenciesMeta": {
		"better-auth": {
			"optional": true
		},
		"better-sqlite3": {
			"optional": true
		}
	},
	"devDependencies": {
		"@fcalell/typescript-config": "workspace:*",
		"@types/better-sqlite3": "^7.6.13",
		"better-auth": "^1.5.5",
		"better-sqlite3": "^12.8.0",
		"typescript": "^5.9.3"
	}
}
