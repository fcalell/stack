{
	"name": "@fcalell/db",
	"version": "0.0.0",
	"type": "module",
	"imports": {
		"#*": "./src/*.ts"
	},
	"exports": {
		".": "./src/kit/config.ts",
		"./orm": "./src/orm.ts",
		"./d1": "./src/d1/client.ts",
		"./sqlite": "./src/sqlite/client.ts",
		"./kit": "./src/kit/config.ts",
		"./auth": "./src/auth/define.ts",
		"./auth/factory": "./src/auth/factory.ts",
		"./auth/access": "./src/auth/access.ts",
		"./auth/infer": "./src/auth/infer.ts"
	},
	"bin": {
		"db-kit": "./src/kit/cli.ts"
	},
	"license": "MIT",
	"scripts": {
