		"@types/node": "^25.5.0",
		"better-auth": "^1.5.5",
		"better-sqlite3": "^12.8.0",
		"drizzle-kit": "^0.31.9",
		"tsx": "^4.19.0",
		"typescript": "^5.9.3"
	}
