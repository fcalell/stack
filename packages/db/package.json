			"optional": true
		},
		"@better-auth/cli": {
			"optional": true
		},
		"better-sqlite3": {
			"optional": true
		}
	},
	"devDependencies": {
		"@better-auth/cli": "^1.4.21",
		"@fcalell/typescript-config": "workspace:*",
