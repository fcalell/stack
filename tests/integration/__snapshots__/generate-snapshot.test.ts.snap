exports[`generate pipeline snapshot > api-only: worker without frontend 1`] = `
{
  "appCss": null,
  "entry": null,
  "files": [
    {
      "content": "// Generated by @fcalell/cli — do not edit.
",
      "path": "src/worker/routes/index.ts",
    },
  ],
  "html": null,
  "providers": null,
  "viteConfig": null,
  "worker": "import * as schema from "../src/schema";
import createWorker from "@fcalell/plugin-api/runtime";
import * as routes from "../src/worker/routes";
import dbRuntime from "@fcalell/plugin-db/runtime";
const worker = createWorker({ prefix: "/rpc", cors: ["https://example.com"] }).use(dbRuntime({ binding: "DB_MAIN", schema: schema })).handler(routes);
export type AppRouter = typeof worker._router;
export default worker;
",
  "wrangler": "name = "test-app"
compatibility_date = "2025-01-01"
main = "worker.ts"

[[d1_databases]]
binding = "DB_MAIN"
database_id = "abc-123"
database_name = "abc-123"
",
}
`;

